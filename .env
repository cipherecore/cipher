# CiphereCore Web - Environment Variables

# Deployment
NODE_ENV=production
SITE_URL=https://cipherecore.com
RENDER_ENV=production

# Optional: API endpoints (if you add a backend later)
# REACT_APP_API_URL=https://api.cipherecore.com
# REACT_APP_API_KEY=your_api_key_here

# Optional: Third-party services
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# Analytics (if needed)
# GOOGLE_ANALYTICS_ID=
# MIXPANEL_TOKEN=
