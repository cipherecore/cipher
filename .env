# CiphereCore Web - Environment Variables

# Deployment
NODE_ENV=production
SITE_URL=https://cipherecore.vercel.app # Change to your custom domain if needed
VERCEL=1

# Backend & External Services (for future use)
# VERCEL_URL is automatically provided by Vercel for preview deployments
# API_URL=https://api.cipherecore.com
# API_KEY=your_api_key_here

# Mailer Settings
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# Analytics & SEO
# GOOGLE_ANALYTICS_ID=
# MIXPANEL_TOKEN=
# VERCEL_ENV=production

